# Copy to /opt/askyy/.env on the VM (never commit .env).
# Used by: docker compose -f docker-compose.prod.yml --env-file .env

# --- Images (GitHub Actions sets IMAGE_TAG on deploy) ---
GHCR_IMAGE_PREFIX=ghcr.io/YOUR_GITHUB_USERNAME
IMAGE_TAG=latest

# --- Host ports (hotel10 uses 3000 and 7000 — keep these different) ---
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3001

# --- Postgres (internal Docker network only) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=askyy

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=152.67.28.191,askyy.example.com
USE_HTTPS=False

# CORS / CSRF — use your public frontend URL (IP or domain)
CORS_ALLOWED_ORIGINS=http://152.67.28.191:3001
CSRF_TRUSTED_ORIGINS=http://152.67.28.191:3001

# --- Frontend build args (baked into image at build time in CI) ---
VITE_API_BASE_URL=http://152.67.28.191:8000/api
VITE_GOOGLE_CLIENT_ID=

# --- App URLs ---
FRONTEND_URL=http://152.67.28.191:3001
GOOGLE_DRIVE_REDIRECT_URI=http://152.67.28.191:8000/api/sources/google/callback/

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Email (Gmail App Password) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_SUBJECT_PREFIX=Askyy

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_TOKEN_ENCRYPTION_KEY=

# --- OpenAI (RAG) ---
OPENAI_API_KEY=

# Optional RAG tuning
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_CHAT_MODEL=gpt-4o-mini
