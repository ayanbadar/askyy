# Django
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker Compose pgvector — comment out to use SQLite)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/askyy

# Redis (Docker Compose)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT (djangorestframework-simplejwt)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email — Google SMTP (Gmail). Use an App Password, not your Google account password.
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_SUBJECT_PREFIX=Askyy
SIGNUP_OTP_LIFETIME_MINUTES=10
SIGNUP_OTP_MAX_ATTEMPTS=5

# Google SSO + Drive (OAuth 2.0 Web client from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/sources/google/callback/
GOOGLE_TOKEN_ENCRYPTION_KEY=
FRONTEND_URL=http://localhost:5173

# OpenAI (required for RAG chatbot)
OPENAI_API_KEY=
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_MAX_CITATIONS=3
RAG_RETRIEVAL_CANDIDATES=20
